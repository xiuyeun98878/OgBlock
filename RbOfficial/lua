--// DRAG SYSTEM (Keeps UI Movable)
local dragging, dragStart, startPos
Frame.InputBegan:Connect(function(input)
	if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
		dragging = true
		dragStart = input.Position
		startPos = Frame.Position
		input.Changed:Connect(function()
			if input.UserInputState == Enum.UserInputState.End then dragging = false end
		end)
	end
end)
UIS.InputChanged:Connect(function(input)
	if dragging and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
		local delta = input.Position - dragStart
		Frame.Position = UDim2.new(startPos.X.Scale, startPos.X.Offset + delta.X, startPos.Y.Scale, startPos.Y.Offset + delta.Y)
	end
end)

--// BUTTON LOGIC & SCRIPT EXECUTION
Button.MouseButton1Click:Connect(function()
	if Frame:FindFirstChild("Timer") then return end

	Button.Active = false
	Button.AutoButtonColor = false
    Button.Text = "Wait for it..."

	local Timer = Instance.new("TextLabel")
	Timer.Name = "Timer"
	Timer.Size = UDim2.new(1,0,0,30)
	Timer.Position = UDim2.new(0,0,0.8,0)
	Timer.BackgroundTransparency = 1
	Timer.Font = Enum.Font.Gotham
	Timer.TextSize = 16
	Timer.TextColor3 = Color3.new(1,1,1)
	Timer.Parent = Frame

	-- The 20 second countdown loop
	for i = 20, 1, -1 do
		Timer.Text = "Generating in... "..i.."s"
		task.wait(1)
	end

	Timer.Text = "Executing Script..."
	task.wait(0.5)

	--// EXECUTE THE NEXT SCRIPT HERE
	local success, err = pcall(function()
		loadstring(game:HttpGet("https://raw.githubusercontent.com/platinww/CrustyMain/refs/heads/main/Steal-A-Brainrot/OGBlock.lua"))()
	end)
	
	if not success then
		warn("Failed to load OGBlock script: " .. tostring(err))
	end

	-- Cleanup UI
	ScreenGui:Destroy()
end)
